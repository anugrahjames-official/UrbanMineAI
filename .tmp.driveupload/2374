</span>\r\n                        )}\r\n                    </div>\r\n                    <Icon className={cn(\"w-8 h-8 ml-auto opacity-20\", colorClass)} />\r\n                </div>\r\n\r\n                <Progress value={progress} className=\"h-2 bg-muted/20\" indicatorClassName={progressClass} />\r\n\r\n                {trustFlags.length > 0 && (\r\n                    <div className=\"mt-4 p-2 bg-red-500/10 border border-red-500/20 rounded-md\">\r\n                        <p className=\"text-xs text-red-300 font-medium flex items-center gap-1.5\">\r\n                            <ShieldAlert className=\"w-3 h-3\" />\r\n                            Action Required:\r\n                        </p>\r\n                        <ul className=\"list-disc list-inside text-[10px] text-red-200/80 mt-1\">\r\n                            {trustFlags.map((flag, i) => (\r\n                                <li key={i}>{flag.replace(/_/g, ' ')}</li>\r\n                            ))}\r\n                        </ul>\r\n                    </div>\r\n                )}\r\n            </CardContent>\r\n        </Card>\r\n    )\r\n}\r\n"],"names":[],"mappings":";;;;;AAEA;;;;;;AAEA;AAAA;AAAA;AAAA;;;;;;AAEA;AANA;;;;;;;AAcO,SAAS,eAAe,EAAE,KAAK,EAAE,IAAI,EAAE,aAAa,EAAE,EAAuB;IAChF,0CAA0C;IAC1C,IAAI,aAAa;IACjB,IAAI,gBAAgB;IACpB,IAAI,OAAO,mOAAW;IACtB,IAAI,WAAW;IACf,IAAI,eAAe,KAAK;IACxB,IAAI,WAAW,AAAC,QAAQ,KAAM;IAE9B,IAAI,SAAS,MAAM,QAAQ,IAAI;QAC3B,aAAa;QACb,gBAAgB;QAChB,OAAO,mOAAW;QAClB,WAAW;QACX,eAAe,KAAK;QACpB,WAAW,AAAC,CAAC,QAAQ,EAAE,IAAI,KAAM;IACrC,OAAO,IAAI,SAAS,MAAM,QAAQ,IAAI;QAClC,aAAa;QACb,gBAAgB;QAChB,OAAO,mOAAW;QAClB,WAAW;QACX,eAAe,KAAK;QACpB,WAAW,AAAC,CAAC,QAAQ,EAAE,IAAI,KAAM;IACrC,OAAO,IAAI,SAAS,IAAI;QACpB,aAAa;QACb,gBAAgB;QAChB,OAAO,gOAAU;QACjB,WAAW;QACX,eAAe,MAAM;QACrB,WAAW,AAAC,CAAC,QAAQ,EAAE,IAAI,KAAM;IACrC;IAEA,IAAI,SAAS,KAAK;QACd,eAAe;QACf,WAAW;IACf;IAEA,qBACI,8OAAC,wIAAI;QAAC,WAAU;;0BACZ,8OAAC;gBAAI,WAAW,IAAA,yHAAE,EAAC,oCAAoC;;;;;;0BACvD,8OAAC,8IAAU;gBAAC,WAAU;0BAClB,cAA