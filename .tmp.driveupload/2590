    {"offset": {"line": 16, "column": 0}, "map": {"version":3,"sources":["file:///C:/Users/anugr/Serious_Projects/UrbanMineAI/src/components/auth/SignOutButton.tsx"],"sourcesContent":["\"use client\";\r\n\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { LogOut } from \"@/components/icons\";\r\nimport { createClient } from \"@/lib/supabase\";\r\nimport { useRouter } from \"next/navigation\";\r\nimport { useState } from \"react\";\r\n\r\nexport function SignOutButton() {\r\n    const router = useRouter();\r\n    const [isSigningOut, setIsSigningOut] = useState(false);\r\n\r\n    async function signOut() {\r\n        setIsSigningOut(true);\r\n        try {\r\n            const supabase = createClient();\r\n            await supabase.auth.signOut();\r\n            router.push(\"/login\");\r\n        } catch (error) {\r\n            console.error(\"Error signing out:\", error);\r\n        } finally {\r\n            setIsSigningOut(false);\r\n        }\r\n    }\r\n\r\n    return (\r\n        <button\r\n            onClick={signOut}\r\n            disabled={isSigningOut}\r\n            className=\"flex items-center gap-2 text-red-500 hover:text-red-400 hover:bg-red-500/10 px-4 py-2 rounded-xl transition-all text-sm font-semibold w-full sm:w-auto justify-center group disabled:opacity-50\"\r\n        >\r\n            <LogOut size={18} className=\"transition-transform group-hover:scale-110\" />\r\n            {isSigningOut ? \"Signing out...\" : \"Sign Out\"}\r\n        </button>\r\n    );\r\n}\r\n"],"names":[],"mappings":";;;;;AAGA;AAAA;AACA;AACA;AACA;AANA;;;;;;AAQO,SAAS;IACZ,MAAM,SAAS,IAAA,+IAAS;IACxB,MAAM,CAAC,cAAc,gBAAgB,GAAG,IAAA,iNAAQ,EAAC;IAEjD,eAAe;QACX,gBAAgB;QAChB,IAAI;YACA,MAAM,WAAW,IAAA,sIAAY;YAC7B,MAAM,SAAS,IAAI,CAAC,OAAO;YAC3B,OAAO,IAAI,CAAC;QAChB,EAAE,OAAO,OAAO;YACZ,QAAQ,KAAK,CAAC,sBAAsB;QACxC,SAAU;YACN,gBAAgB;QACpB;IACJ;IAEA,qBACI,8OAAC;QACG,SAAS;QACT,UAAU;QACV,WAAU;;0BAEV,8OAAC,oNAAM;gBAAC,MAAM;gBAAI,WAAU;;;;;;YAC3B,eAAe,mBAAmB;;;;;;;AAG/C"}}