or fetching negotiations:', error)\r\n        return []\r\n    }\r\n\r\n    if (!negotiations || negotiations.length === 0) return []\r\n\r\n    // Fetch last message for each negotiation for sidebar preview\r\n    const negotiationIds = negotiations.map(n => n.id)\r\n    const { data: lastMessages } = await supabase\r\n        .from('chat_messages')\r\n        .select('negotiation_id, content, role')\r\n        .in('negotiation_id', negotiationIds)\r\n        .order('created_at', { ascending: false })\r\n\r\n    // Group: take only the first (latest) message per negotiation\r\n    const lastMsgMap: Record<string, string> = {}\r\n    lastMessages?.forEach(msg => {\r\n        if (!lastMsgMap[msg.negotiation_id]) {\r\n            const prefix = msg.role === 'assistant' ? 'AI Broker: ' : ''\r\n            lastMsgMap[msg.negotiation_id] = prefix + msg.content.slice(0, 80)\r\n        }\r\n    })\r\n\r\n    return negotiations.map(n => ({\r\n        ...n,\r\n        last_message: lastMsgMap[n.id] || '',\r\n    }))\r\n}\r\n\r\n/**\r\n * Get a single negotiation with all its messages.\r\n */\r\nexport async function getNegotiation(id: string): Promise<{\r\n    negotiation: Negotiation | null\r\n    messages: ChatMessage[]\r\n}> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) return { negotiation: null, messages: [] }\r\n\r\n    const { data: negotiation, error: negError } = await supabase\r\n        .from('negotiations')\r\n        .select('*')\r\n        .eq('id', id)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    if (negError || !negotiation) {\r\n        console.error('Error fetching negotiation:', negError)\r\n        return { negotiation: null, messages: [] }\r\n    }\r\n\r\n    const { data: messages, error: msgError } = await supabase\r\n        .from('chat_messages')\r\n        .select('*')\r\n        .eq('negotiation_id', id)\r\n        .order('created_at', { ascending: true })\r\n\r\n    if (msgError) {\r\n        console.error('Error fetching messages:', msgError)\r\n    }\r\n\r\n    return {\r\n        negotiation,\r\n        messages: messages || [],\r\n    }\r\n}\r\n\r\n/**\r\n * Create a new negotiation session.\r\n * Optionally attach inventory items being negotiated.\r\n */\r\nexport async function createNegotiation(\r\n    title: string,\r\n    itemIds: string[] = []\r\n): Promise<{ id: string } | null> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    const { data, error } = await supabase\r\n        .from('negotiations')\r\n        .insert({\r\n            dealer_id: user.id,\r\n            title: title || 'New Negotiation',\r\n            item_ids: itemIds,\r\n            status: 'active',\r\n        })\r\n        .select('id')\r\n        .single()\r\n\r\n    if (error) {\r\n        console.error('Error creating negotiation:', error)\r\n        throw new Error('Failed to create negotiation')\r\n    }\r\n\r\n    revalidatePath('/dealer/chat')\r\n    return data\r\n}\r\n\r\n/**\r\n * Save a single chat message to the database.\r\n */\r\nexport async function saveMessage(\r\n    negotiationId: string,\r\n    role: 'user' | 'assistant' | 'system',\r\n    content: string,\r\n    metadata: Record<string, unknown> = {}\r\n): Promise<ChatMessage | null> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    // Verify user owns this negotiation\r\n    const { data: negotiation } = await supabase\r\n        .from('negotiations')\r\n        .select('id')\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    if (!negotiation) throw new Error('Negotiation not found')\r\n\r\n    const { data: message, error } = await supabase\r\n        .from('chat_messages')\r\n        .insert({\r\n            negotiation_id: negotiationId,\r\n            role,\r\n            content,\r\n            metadata,\r\n        })\r\n        .select('*')\r\n        .single()\r\n\r\n    if (error) {\r\n        console.error('Error saving message:', error)\r\n        throw new Error('Failed to save message')\r\n    }\r\n\r\n    // Update negotiation's last_message_at timestamp\r\n    await supabase\r\n        .from('negotiations')\r\n        .update({ last_message_at: new Date().toISOString() })\r\n        .eq('id', negotiationId)\r\n\r\n    return message\r\n}\r\n\r\n/**\r\n * Update the proposed deal on a negotiation (called after AI generates a deal).\r\n */\r\nexport async function updateNegotiationOffer(\r\n    negotiationId: string,\r\n    offer: {\r\n        proposed_price_per_unit: number\r\n        proposed_total: number\r\n        proposed_weight: number\r\n        proposed_unit?: string\r\n    }\r\n): Promise<void> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    const { error } = await supabase\r\n        .from('negotiations')\r\n        .update({\r\n            proposed_price_per_unit: offer.proposed_price_per_unit,\r\n            proposed_total: offer.proposed_total,\r\n            proposed_weight: offer.proposed_weight,\r\n            proposed_unit: offer.proposed_unit || 'kg',\r\n        })\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n\r\n    if (error) {\r\n        console.error('Error updating offer:', error)\r\n        throw new Error('Failed to update offer')\r\n    }\r\n}\r\n\r\n/**\r\n * Accept the current proposed offer. Creates a transaction and closes the negotiation.\r\n */\r\nexport async function acceptOffer(negotiationId: string): Promise<{ transactionId: string }> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    // 1. Fetch the negotiation\r\n    const { data: negotiation, error: negError } = await supabase\r\n        .from('negotiations')\r\n        .select('*')\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    if (negError || !negotiation) throw new Error('Negotiation not found')\r\n    if (!negotiation.proposed_total) throw new Error('No active offer to accept')\r\n\r\n    // 2. Create a transaction\r\n    const { data: transaction, error: txError } = await supabase\r\n        .from('transactions')\r\n        .insert({\r\n            supplier_id: user.id,\r\n            item_ids: negotiation.item_ids || [],\r\n            price_total: negotiation.proposed_total,\r\n            status: 'agreed',\r\n            material_breakdown: {\r\n                price_per_unit: negotiation.proposed_price_per_unit,\r\n                weight: negotiation.proposed_weight,\r\n                unit: negotiation.proposed_unit,\r\n            },\r\n        })\r\n        .select('id')\r\n        .single()\r\n\r\n    if (txError || !transaction) {\r\n        console.error('Error creating transaction:', txError)\r\n        throw new Error('Failed to create transaction')\r\n    }\r\n\r\n    // 3. Update negotiation status and link transaction\r\n    await supabase\r\n        .from('negotiations')\r\n        .update({\r\n            status: 'accepted',\r\n            transaction_id: transaction.id,\r\n        })\r\n        .eq('id', negotiationId)\r\n\r\n    // 4. Update items status to 'sold'\r\n    if (negotiation.item_ids && negotiation.item_ids.length > 0) {\r\n        await supabase\r\n            .from('items')\r\n            .update({ status: 'sold' })\r\n            .in('id', negotiation.item_ids)\r\n    }\r\n\r\n    // 5. Save a system message\r\n    await supabase\r\n        .from('chat_messages')\r\n        .insert({\r\n            negotiation_id: negotiationId,\r\n            role: 'system',\r\n            content: `Deal accepted! Transaction #${transaction.id.slice(0, 8)} created for $${negotiation.proposed_total}.`,\r\n            metadata: { transaction_id: transaction.id },\r\n        })\r\n\r\n    revalidatePath('/dealer/chat')\r\n    revalidatePath('/dealer/dashboard')\r\n    revalidatePath('/dealer/inventory')\r\n\r\n    return { transactionId: transaction.id }\r\n}\r\n\r\n/**\r\n * Close or cancel a negotiation without accepting.\r\n */\r\nexport async function closeNegotiation(negotiationId: string): Promise<void> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    const { error } = await supabase\r\n        .from('negotiations')\r\n        .update({ status: 'cancelled' })\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n\r\n    if (error) {\r\n        console.error('Error closing negotiation:', error)\r\n        throw new Error('Failed to close negotiation')\r\n    }\r\n\r\n    revalidatePath('/dealer/chat')\r\n}\r\n\r\n/**\r\n * Get items context for the broker (metadata, grades, etc.)\r\n * Used by the API route to build AI context.\r\n */\r\nexport async function getNegotiationContext(negotiationId: string): Promise<{\r\n    items: Array<{\r\n        id: string\r\n        category: string\r\n        grade: string\r\n        weight: string\r\n        estimatedValue: string\r\n        image_url: string\r\n    }>\r\n    marketPrices: Array<{\r\n        name: string\r\n        symbol: string\r\n        price: number\r\n        unit: string\r\n    }>\r\n    dealerName: string\r\n    trustScore: number\r\n}> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    // Fetch negotiation to get item_ids\r\n    const { data: negotiation } = await supabase\r\n        .from('negotiations')\r\n        .select('item_ids')\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    // Fetch items\r\n    let items: Array<{\r\n        id: string\r\n        category: string\r\n        grade: string\r\n        weight: string\r\n        estimatedValue: string\r\n        image_url: string\r\n    }> = []\r\n\r\n    if (negotiation?.item_ids && negotiation.item_ids.length > 0) {\r\n        const { data: rawItems } = await supabase\r\n            .from('items')\r\n            .select('id, image_url, metadata')\r\n            .in('id', negotiation.item_ids)\r\n\r\n        items = (rawItems || []).map(item => {\r\n            const meta = item.metadata as Record<string, string> | null\r\n            return {\r\n                id: item.id,\r\n                category: meta?.category || meta?.classification || 'Unknown',\r\n                grade: meta?.grade || 'Ungraded',\r\n                weight: meta?.weight || 'Unknown',\r\n                estimatedValue: String(meta?.estimatedValue || '0'),\r\n                image_url: item.image_url,\r\n            }\r\n        })\r\n    }\r\n\r\n    // Fetch market prices\r\n    const { data: prices } = await supabase\r\n        .from('market_prices')\r\n        .select('name, symbol, price, unit')\r\n        .order('name')\r\n\r\n    // Fetch dealer profile\r\n    const { data: profile } = await supabase\r\n        .from('users')\r\n        .select('first_name, last_name, trust_score, business_name')\r\n        .eq('id', user.id)\r\n        .single()\r\n\r\n    const dealerName = profile?.business_name\r\n        || [profile?.first_name, profile?.last_name].filter(Boolean).join(' ')\r\n        || 'Dealer'\r\n\r\n    return {\r\n        items,\r\n        marketPrices: prices || [],\r\n        dealerName,\r\n        trustScore: profile?.trust_score || 30,\r\n    }\r\n}\r\n"],"names":[],"mappings":";;;;;;;MAkIsB,wBAAA,WAAA,GAAA,IAAA,+OAAA,EAAA,8CAAA,oOAAA,EAAA,KAAA,GAAA,0OAAA,EAAA,qDAAA"}},
    {"offset": {"line": 655, "column": 0}, "map": {"version":3,"sources":["file:///C:/Users/anugr/Serious_Projects/UrbanMineAI/src/app/actions/dealer.ts"],"sourcesContent":["'use server'\r\n\r\nimport { createClient } from '@/lib/supabase/server'\r\nimport { redirect } from 'next/navigation'\r\nimport { revalidatePath } from 'next/cache'\r\nimport { getUserProfile } from './user'\r\n\r\ninterface ItemMetadata {\r\n    category?: string;\r\n    weight?: string;\r\n    estimatedValue?: string | number;\r\n    grade?: string;\r\n}\r\n\r\ninterface UserProfile {\r\n    email: string;\r\n    role: string;\r\n    tier?: string;\r\n}\r\n\r\nexport async function getDealerProfile() {\r\n    const profile = await getUserProfile();\r\n\r\n    return {\r\n        name: profile.name,\r\n        email: profile.email,\r\n        trustScore: profile.trust_score,\r\n        trustFlags: profile.trust_flags,\r\n        tier: profile.tier,\r\n        isVerified: profile.isVerified\r\n    }\r\n}\r\n\r\nexport async function getDealerInventory() {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) return []\r\n\r\n    const { data: items, error } = await supabase\r\n        .from('items')\r\n        .select('*')\r\n        .eq('user_id', user.id)\r\n        .order('created_at', { ascending: false })\r\n\r\n    if (error) {\r\n        console.error('Error fetching inventory:', error)\r\n        return []\r\n    }\r\n\r\n    return items.map(item => {\r\n        const meta = item.metadata as unknown as ItemMetadata\r\n        return {\r\n            id: item.id,\r\n            title: meta?.category || 'Unknown Item',\r\n            weight: meta?.weight || 'N/A',\r\n            value: meta?.estimatedValue || '$0',\r\n            grade: meta?.grade || 'Ungraded',\r\n            image: item.image_url,\r\n            created_at: item.created_at,\r\n            status: item.status,\r\n            variant: meta?.grade?.includes('A') ? 'success' : meta?.grade?.includes('B') ? 'warning' : 'error'\r\n        }\r\n    })\r\n}\r\n\r\nexport async function getRecentDealerInventory() {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) return []\r\n\r\n    const { data: items } = await supabase\r\n        .from('items')\r\n        .select('*')\r\n        .eq('user_id', user.id)\r\n        .order('created_at', { ascending: false })\r\n        .limit(4)\r\n\r\n    return items?.map(item => {\r\n        const meta = item.metadata as unknown as ItemMetadata\r\n        return {\r\n            id: item.id,\r\n            title: meta?.category || 'Unknown Item',\r\n            weight: meta?.weight || 'N/A',\r\n            value: meta?.estimatedValue || '$0',\r\n            grade: meta?.grade || 'Ungraded',\r\n            image: item.image_url,\r\n            created_at: item.created_at,\r\n            variant: meta?.grade?.includes('A') ? 'success' : meta?.grade?.includes('B') ? 'warning' : 'error'\r\n        }\r\n    }) || []\r\n}\r\n\r\nexport async function getDealerAnalytics() {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) return null\r\n\r\n    // Fetch items for GMV and rejected counts\r\n    const { data: items } = await supabase\r\n        .from('items')\r\n        .select('metadata, status, created_at')\r\n        .eq('user_id', user.id)\r\n\r\n    let inventoryValue = 0\r\n    const rejectedCount = 0 // Placeholder until we have a 'rejected' status or table\r\n    let scannedToday = 0\r\n    const today = new Date().toISOString().split('T')[0]\r\n\r\n    // Initialize daily revenue for chart (last 7 days)\r\n    const dailyRevenue = Array(7).fill(0)\r\n    const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']\r\n    const last7DaysLabels = []\r\n\r\n    for (let i = 6; i >= 0; i--) {\r\n        const d = new Date()\r\n        d.setDate(d.getDate() - i)\r\n        last7DaysLabels.push(days[d.getDay()])\r\n    }\r\n\r\n    // Composition Map\r\n    const composition: Record<string, number> = {}\r\n    let totalItems = 0\r\n    let totalEwasteWeight = 0;\r\n\r\n    items?.forEach(item => {\r\n        const meta = item.metadata as unknown as ItemMetadata\r\n\r\n        // GMV Calculation - Only count items that are NOT sold yet? Or all inventory value?\r\n        // Usually \"Inventory Value\" implies current items on hand (pending/listed).\r\n        if (item.status !== 'sold') {\r\n            if (meta?.estimatedValue) {\r\n                const val = typeof meta.estimatedValue === 'string'\r\n                    ? parseFloat(meta.estimatedValue.replace(/[^0-9.]/g, ''))\r\n                    : meta.estimatedValue\r\n                if (!isNaN(val as number)) inventoryValue += (val as number)\r\n            }\r\n        }\r\n\r\n        // E-Waste Weight Calculation\r\n        if (meta?.weight) {\r\n            const weightVal = parseFloat(meta.weight.replace(/[^0-9.]/g, ''))\r\n            if (!isNaN(weightVal)) totalEwasteWeight += weightVal\r\n        }\r\n\r\n        if (item.created_at.startsWith(today)) {\r\n            scannedToday++\r\n        }\r\n\r\n        // Composition\r\n        const category = meta?.category || 'Other'\r\n        composition[category] = (composition[category] || 0) + 1\r\n        totalItems++\r\n    })\r\n\r\n    // Transactions Count\r\n    const { count: transactionsCount } = await supabase\r\n        .from('transactions')\r\n        .select('*', { count: 'exact', head: true })\r\n        .or(`supplier_id.eq.${user.id},buyer_id.eq.${user.id}`)\r\n\r\n    // Active Deals\r\n    const { count: activeDeals } = await supabase\r\n        .from('transactions')\r\n        .select('*', { count: 'exact', head: true })\r\n        .or(`supplier_id.eq.${user.id},buyer_id.eq.${user.id}`)\r\n        .in('status', ['negotiating', 'agreed', 'pending'])\r\n\r\n    // Weekly Revenue (Completed Sales)\r\n    const { data: completedSales } = await supabase\r\n        .from('transactions')\r\n        .select('created_at, price_total')\r\n        .eq('supplier_id', user.id) // As a dealer, revenue comes from selling (supplier)\r\n        .in('status', ['paid', 'completed'])\r\n        .gte('created_at', new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString())\r\n\r\n    completedSales?.forEach(sale => {\r\n        const date = new Date(sale.created_at)\r\n        const dayIndex = 6 - Math.floor((Date.now() - date.getTime()) / (1000 * 60 * 60 * 24))\r\n        if (dayIndex >= 0 && dayIndex < 7) {\r\n            dailyRevenue[dayIndex] += Number(sale.price_total)\r\n        }\r\n    })\r\n\r\n    // Formatting composition for chart\r\n    const compositionData = Object.entries(composition).map(([label, count]) => ({\r\n        label,\r\n        value: totalItems > 0 ? `${Math.round((count / totalItems) * 100)}%` : '0%'\r\n    })).sort((a, b) => parseInt(b.value) - parseInt(a.value)).slice(0, 4)\r\n\r\n    // Avg Deal Time (Mock logic for now as we don't have historical closed deals to average yet)\r\n    const avgDealTime = \"N/A\"\r\n\r\n    return {\r\n        inventoryValue,\r\n        activeDeals: activeDeals || 0,\r\n        transactionsCount: transactionsCount || 0,\r\n        totalEwasteWeight,\r\n        scannedToday,\r\n        avgDealTime,\r\n        rejectedCount,\r\n        weeklyRevenue: dailyRevenue,\r\n        weeklyLabels: last7DaysLabels,\r\n        composition: compositionData\r\n    }\r\n}\r\n\r\nexport async function publishItems(itemIds: string[]) {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) {\r\n        throw new Error(\"Unauthorized\")\r\n    }\r\n\r\n    // Verify user is a dealer\r\n    const { data: profile } = await supabase\r\n        .from('users')\r\n        .select('role')\r\n        .eq('id', user.id)\r\n        .single()\r\n\r\n    if (profile?.role !== 'dealer') {\r\n        throw new Error(\"Unauthorized. Only dealers can publish items.\")\r\n    }\r\n\r\n    const { error } = await supabase\r\n        .from('items')\r\n        .update({ status: 'listed' })\r\n        .in('id', itemIds)\r\n        .eq('user_id', user.id) // Ensure user owns the items\r\n\r\n    if (error) {\r\n        console.error('Error publishing items:', error)\r\n        throw new Error(\"Failed to publish items\")\r\n    }\r\n\r\n    redirect('/dealer/inventory')\r\n}\r\n\r\nexport async function updateItemMetadata(itemId: string, metadata: Partial<ItemMetadata>) {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) {\r\n        throw new Error(\"Unauthorized\")\r\n    }\r\n\r\n    // Verify user is a dealer\r\n    const { data: profile } = await supabase\r\n        .from('users')\r\n        .select('role')\r\n        .eq('id', user.id)\r\n        .single()\r\n\r\n    if (profile?.role !== 'dealer') {\r\n        throw new Error(\"Unauthorized. Only dealers can update item metadata.\")\r\n    }\r\n\r\n    // First fetch existing metadata to merge\r\n    const { data: item, error: fetchError } = await supabase\r\n        .from('items')\r\n        .select('metadata')\r\n        .eq('id', itemId)\r\n        .eq('user_id', user.id)\r\n        .single()\r\n\r\n    if (fetchError || !item) {\r\n        console.error('Error fetching item for update:', fetchError)\r\n        throw new Error(\"Item not found\")\r\n    }\r\n\r\n    const currentMetadata = item.metadata as unknown as ItemMetadata\r\n    const newMetadata = { ...currentMetadata, ...metadata }\r\n\r\n    const { error: updateError } = await supabase\r\n        .from('items')\r\n        .update({ metadata: newMetadata })\r\n        .eq('id', itemId)\r\n        .eq('user_id', user.id)\r\n\r\n    if (updateError) {\r\n        console.error('Error updating i