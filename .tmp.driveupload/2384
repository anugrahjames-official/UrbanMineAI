layName = \"Button\"\n\nexport { Button, buttonVariants }\n"],"names":[],"mappings":";;;;;;;AAAA;AACA;AACA;AAEA;;;;;;AAEA,MAAM,iBAAiB,IAAA,uKAAG,EACxB,+TACA;IACE,UAAU;QACR,SAAS;YACP,SACE;YACF,WACE;YACF,OAAO;YACP,MAAM;QACR;QACA,MAAM;YACJ,SAAS;YACT,IAAI;YACJ,IAAI;YACJ,MAAM;QACR;IACF;IACA,iBAAiB;QACf,SAAS;QACT,MAAM;IACR;AACF;AASF,MAAM,uBAAS,mNAAgB,CAC7B,CAAC,EAAE,SAAS,EAAE,OAAO,EAAE,IAAI,EAAE,UAAU,KAAK,EAAE,GAAG,OAAO,EAAE;IACxD,MAAM,OAAO,UAAU,wKAAI,GAAG;IAC9B,qBACE,8OAAC;QACC,WAAW,IAAA,yHAAE,EAAC,eAAe;YAAE;YAAS;YAAM;QAAU;QACxD,KAAK;QACJ,GAAG,KAAK;;;;;;AAGf;AAEF,OAAO,WAAW,GAAG"}},
    {"offset": {"line": 62, "column": 0}, "map": {"version":3,"sources":["file:///C:/Users/anugr/Serious_Projects/UrbanMineAI/src/components/ui/scroll-area.tsx"],"sourcesContent":["\"use client\"\n\nimport * as React from \"react\"\nimport * as ScrollAreaPrimitive from \"@radix-ui/react-scroll-area\"\n\nimport { cn } from \"@/lib/utils\"\n\nconst ScrollArea = React.forwardRef<\n  React.ElementRef<typeof ScrollAreaPrimitive.Root>,\n  React.ComponentPropsWithoutRef<typeof ScrollAreaPrimitive.Root>\n>(({ className, children, ...props }, ref) => (\n  <ScrollAreaPrimitive.Root\n    ref={ref}\n    className={cn(\"relative overflow-hidden\", className)}\n    {...props}\n  >\n    <ScrollAreaPrimitive.Viewport className=\"h-full w-full rounded-[inherit]\">\n      {children}\n    </ScrollAreaPrimitive.Viewport>\n    <ScrollBar />\n    <ScrollAreaPrimitive.Corner />\n  </ScrollAreaPrimitive.Root>\n))\nScrollArea.displayName = ScrollAreaPrimitive.Root.displayName\n\nconst ScrollBar = React.forwardRef<\n  React.ElementRef<typeof ScrollAreaPrimitive.ScrollAreaScrollbar>,\n  React.ComponentPropsWithoutRef<typeof ScrollAreaPrimitive.ScrollAreaScrollbar>\n>(({ className, orientation = \"vertical\", ...props }, ref) => (\n  <ScrollAreaPrimitive.ScrollAreaScrollbar\n    ref={ref}\n    orientation={orientation}\n    className={cn(\n      \"flex touch-none select-none transition-colors\",\n      orientation === \"vertical\" &&\n        \"h-full w-2.5 border-l border-l-transparent p-[1px]\",\n      orientation === \"horizontal\" &&\n        \"h-2.5 flex-col border-t border-t-transparent p-[1px]\",\n      className\n    )}\n    {...props}\n  >\n    <ScrollAreaPrimitive.ScrollAreaThumb className=\"relative flex-1 rounded-full bg-border\" />\n  </ScrollAreaPrimitive.ScrollAreaScrollbar>\n))\nScrollBar.displayName = ScrollAreaPrimitive.ScrollAreaScrollbar.displayName\n\nexport { ScrollArea, ScrollBar }\n"],"names":[],"mappings":";;;;;;;AAEA;AACA;AAEA;AALA;;;;;AAOA,MAAM,2BAAa,mNAAgB,CAGjC,CAAC,EAAE,SAAS,EAAE,QAAQ,EAAE,GAAG,OAAO,EAAE,oBACpC,8OAAC,kLAAwB;QACvB,KAAK;QACL,WAAW,IAAA,yHAAE,EAAC,4BAA4B;QACzC,GAAG,KAAK;;0BAET,8OAAC,sLAA4B;gBAAC,WAAU;0BACrC;;;;;;0BAEH,8OAAC;;;;;0BACD,8OAAC,oLAA0B;;;;;;;;;;;AAG/B,WAAW,WAAW,GAAG,kLAAwB,CAAC,WAAW;AAE7D,MAAM,0BAAY,mNAAgB,CAGhC,CAAC,EAAE,SAAS,EAAE,cAAc,UAAU,EAAE,GAAG,OAAO,EAAE,oBACpD,8OAAC,iMAAuC;QACtC,KAAK;QACL,aAAa;QACb,WAAW,IAAA,yHAAE,EACX,iDACA,gBAAgB,cACd,sDACF,gBAAgB,gBACd,wDACF;QAED,GAAG,KAAK;kBAET,cAAA,8OAAC,6LAAmC;YAAC,WAAU;;;;;;;;;;;AAGnD,UAAU,WAAW,GAAG,iMAAuC,CAAC,WAAW"}},
    {"offset": {"line": 130, "column": 0}, "map": {"version":3,"sources":["file:///C:/Users/anugr/Serious_Projects/UrbanMineAI/src/app/actions/negotiation.ts"],"sourcesContent":["'use server'\r\n\r\nimport { createClient } from '@/lib/supabase/server'\r\nimport { revalidatePath } from 'next/cache'\r\n\r\n// ============================================================\r\n// Types\r\n// ============================================================\r\n\r\nexport interface Negotiation {\r\n    id: string\r\n    dealer_id: string\r\n    title: string\r\n    status: 'active' | 'closed' | 'accepted' | 'cancelled'\r\n    item_ids: string[]\r\n    proposed_price_per_unit: number | null\r\n    proposed_total: number | null\r\n    proposed_weight: number | null\r\n    proposed_unit: string\r\n    transaction_id: string | null\r\n    last_message_at: string\r\n    created_at: string\r\n    // Joined data\r\n    last_message?: string\r\n    message_count?: number\r\n}\r\n\r\nexport interface ChatMessage {\r\n    id: string\r\n    negotiation_id: string\r\n    role: 'user' | 'assistant' | 'system'\r\n    content: string\r\n    metadata: Record<string, unknown>\r\n    created_at: string\r\n}\r\n\r\n// ============================================================\r\n// Negotiation CRUD\r\n// ============================================================\r\n\r\n/**\r\n * List all negotiations for the current dealer, ordered by last_message_at.\r\n * Includes a preview of the last message for sidebar display.\r\n */\r\nexport async function getNegotiations(): Promise<Negotiation[]> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) return []\r\n\r\n    const { data: negotiations, error } = await supabase\r\n        .from('negotiations')\r\n        .select('*')\r\n        .eq('dealer_id', user.id)\r\n        .order('last_message_at', { ascending: false })\r\n\r\n    if (error) {\r\n        console.error('Error fetching negotiations:', error)\r\n        return []\r\n    }\r\n\r\n    if (!negotiations || negotiations.length === 0) return []\r\n\r\n    // Fetch last message for each negotiation for sidebar preview\r\n    const negotiationIds = negotiations.map(n => n.id)\r\n    const { data: lastMessages } = await supabase\r\n        .from('chat_messages')\r\n        .select('negotiation_id, content, role')\r\n        .in('negotiation_id', negotiationIds)\r\n        .order('created_at', { ascending: false })\r\n\r\n    // Group: take only the first (latest) message per negotiation\r\n    const lastMsgMap: Record<string, string> = {}\r\n    lastMessages?.forEach(msg => {\r\n        if (!lastMsgMap[msg.negotiation_id]) {\r\n            const prefix = msg.role === 'assistant' ? 'AI Broker: ' : ''\r\n            lastMsgMap[msg.negotiation_id] = prefix + msg.content.slice(0, 80)\r\n        }\r\n    })\r\n\r\n    return negotiations.map(n => ({\r\n        ...n,\r\n        last_message: lastMsgMap[n.id] || '',\r\n    }))\r\n}\r\n\r\n/**\r\n * Get a single negotiation with all its messages.\r\n */\r\nexport async function getNegotiation(id: string): Promise<{\r\n    negotiation: Negotiation | null\r\n    messages: ChatMessage[]\r\n}> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) return { negotiation: null, messages: [] }\r\n\r\n    const { data: negotiation, error: negError } = await supabase\r\n        .from('negotiations')\r\n        .select('*')\r\n        .eq('id', id)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    if (negError || !negotiation) {\r\n        console.error('Error fetching negotiation:', negError)\r\n        return { negotiation: null, messages: [] }\r\n    }\r\n\r\n    const { data: messages, error: msgError } = await supabase\r\n        .from('chat_messages')\r\n        .select('*')\r\n        .eq('negotiation_id', id)\r\n        .order('created_at', { ascending: true })\r\n\r\n    if (msgError) {\r\n        console.error('Error fetching messages:', msgError)\r\n    }\r\n\r\n    return {\r\n        negotiation,\r\n        messages: messages || [],\r\n    }\r\n}\r\n\r\n/**\r\n * Create a new negotiation session.\r\n * Optionally attach inventory items being negotiated.\r\n */\r\nexport async function createNegotiation(\r\n    title: string,\r\n    itemIds: string[] = []\r\n): Promise<{ id: string } | null> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    const { data, error } = await supabase\r\n        .from('negotiations')\r\n        .insert({\r\n            dealer_id: user.id,\r\n            title: title || 'New Negotiation',\r\n            item_ids: itemIds,\r\n            status: 'active',\r\n        })\r\n        .select('id')\r\n        .single()\r\n\r\n    if (error) {\r\n        console.error('Error creating negotiation:', error)\r\n        throw new Error('Failed to create negotiation')\r\n    }\r\n\r\n    revalidatePath('/dealer/chat')\r\n    return data\r\n}\r\n\r\n/**\r\n * Save a single chat message to the database.\r\n */\r\nexport async function saveMessage(\r\n    negotiationId: string,\r\n    role: 'user' | 'assistant' | 'system',\r\n    content: string,\r\n    metadata: Record<string, unknown> = {}\r\n): Promise<ChatMessage | null> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    // Verify user owns this negotiation\r\n    const { data: negotiation } = await supabase\r\n        .from('negotiations')\r\n        .select('id')\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    if (!negotiation) throw new Error('Negotiation not found')\r\n\r\n    const { data: message, error } = await supabase\r\n        .from('chat_messages')\r\n        .insert({\r\n            negotiation_id: negotiationId,\r\n            role,\r\n            content,\r\n            metadata,\r\n        })\r\n        .select('*')\r\n        .single()\r\n\r\n    if (error) {\r\n        console.error('Error saving message:', error)\r\n        throw new Error('Failed to save message')\r\n    }\r\n\r\n    // Update negotiation's last_message_at timestamp\r\n    await supabase\r\n        .from('negotiations')\r\n        .update({ last_message_at: new Date().toISOString() })\r\n        .eq('id', negotiationId)\r\n\r\n    return message\r\n}\r\n\r\n/**\r\n * Update the proposed deal on a negotiation (called after AI generates a deal).\r\n */\r\nexport async function updateNegotiationOffer(\r\n    negotiationId: string,\r\n    offer: {\r\n        proposed_price_per_unit: number\r\n        proposed_total: number\r\n        proposed_weight: number\r\n        proposed_unit?: string\r\n    }\r\n): Promise<void> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    const { error } = await supabase\r\n        .from('negotiations')\r\n        .update({\r\n            proposed_price_per_unit: offer.proposed_price_per_unit,\r\n            proposed_total: offer.proposed_total,\r\n            proposed_weight: offer.proposed_weight,\r\n            proposed_unit: offer.proposed_unit || 'kg',\r\n        })\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n\r\n    if (error) {\r\n        console.error('Error updating offer:', error)\r\n        throw new Error('Failed to update offer')\r\n    }\r\n}\r\n\r\n/**\r\n * Accept the current proposed offer. Creates a transaction and closes the negotiation.\r\n */\r\nexport async function acceptOffer(negotiationId: string): Promise<{ transactionId: string }> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    // 1. Fetch the negotiation\r\n    const { data: negotiation, error: negError } = await supabase\r\n        .from('negotiations')\r\n        .select('*')\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    if (negError || !negotiation) throw new Error('Negotiation not found')\r\n    if (!negotiation.proposed_total) throw new Error('No active offer to accept')\r\n\r\n    // 2. Create a transaction\r\n    const { data: transaction, error: txError } = await supabase\r\n        .from('transactions')\r\n        .insert({\r\n            supplier_id: user.id,\r\n            item_ids: negotiation.item_ids || [],\r\n            price_total: negotiation.proposed_total,\r\n            status: 'agreed',\r\n            material_breakdown: {\r\n                price_per_unit: negotiation.proposed_price_per_unit,\r\n                weight: negotiation.proposed_weight,\r\n                unit: negotiation.proposed_unit,\r\n            },\r\n        })\r\n        .select('id')\r\n        .single()\r\n\r\n    if (txError || !transaction) {\r\n        console.error('Error creating transaction:', txError)\r\n        throw new Error('Failed to create transaction')\r\n    }\r\n\r\n    // 3. Update negotiation status and link transaction\r\n    await supabase\r\n        .from('negotiations')\r\n        .update({\r\n            status: 'accepted',\r\n            transaction_id: transaction.id,\r\n        })\r\n        .eq('id', negotiationId)\r\n\r\n    // 4. Update items status to 'sold'\r\n    if (negotiation.item_ids && negotiation.item_ids.length > 0) {\r\n        await supabase\r\n            .from('items')\r\n            .update({ status: 'sold' })\r\n            .in('id', negotiation.item_ids)\r\n    }\r\n\r\n    // 5. Save a system message\r\n    await supabase\r\n        .from('chat_messages')\r\n        .insert({\r\n            negotiation_id: negotiationId,\r\n            role: 'system',\r\n            content: `Deal accepted! Transaction #${transaction.id.slice(0, 8)} created for $${negotiation.proposed_total}.`,\r\n            metadata: { transaction_id: transaction.id },\r\n        })\r\n\r\n    revalidatePath('/dealer/chat')\r\n    revalidatePath('/dealer/dashboard')\r\n    revalidatePath('/dealer/inventory')\r\n\r\n    return { transactionId: transaction.id }\r\n}\r\n\r\n/**\r\n * Close or cancel a negotiation without accepting.\r\n */\r\nexport async function closeNegotiation(negotiationId: string): Promise<void> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    const { error } = await supabase\r\n        .from('negotiations')\r\n        .update({ status: 'cancelled' })\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n\r\n    if (error) {\r\n        console.error('Error closing negotiation:', error)\r\n        throw new Error('Failed to close negotiation')\r\n    }\r\n\r\n    revalidatePath('/dealer/chat')\r\n}\r\n\r\n/**\r\n * Get items context for the broker (metadata, grades, etc.)\r\n * Used by the API route to build AI context.\r\n */\r\nexport async function getNegotiationContext(negotiationId: string): Promise<{\r\n    items: Array<{\r\n        id: string\r\n        category: string\r\n        grade: string\r\n        weight: string\r\n        estimatedValue: string\r\n        image_url: string\r\n    }>\r\n    marketPrices: Array<{\r\n        name: string\r\n        symbol: string\r\n        price: number\r\n        unit: string\r\n    }>\r\n    dealerName: string\r\n    trustScore: number\r\n}> {\r\n    const supabase = await createClient()\r\n    const { data: { user } } = await supabase.auth.getUser()\r\n\r\n    if (!user) throw new Error('Unauthorized')\r\n\r\n    // Fetch negotiation to get item_ids\r\n    const { data: negotiation } = await supabase\r\n        .from('negotiations')\r\n        .select('item_ids')\r\n        .eq('id', negotiationId)\r\n        .eq('dealer_id', user.id)\r\n        .single()\r\n\r\n    // Fetch items\r\n    let items: Array<{\r\n        id: string\r\n        category: string\r\n        grade: string\r\n        weight: string\r\n        estimatedValue: string\r\n        image_url: string\r\n    }> = []\r\n\r\n    if (negotiation?.item_ids && negotiation.item_ids.length > 0) {\r\n        const { data: rawItems } = await supabase\r\n            .from('items')\r\n            .select('id, image_url, metadata')\r\n            .in('id', negotiation.item_ids)\r\n\r\n        items = (rawItems || []).map(item => {\r\n            const meta = item.metadata as Record<string, string> | null\r\n            return {\r\n                id: item.id,\r\n                category: meta?.category || meta?.classification || 'Unknown',\r\n                grade: meta?.grade || 'Ungraded',\r\n                weight: meta?.weight || 'Unknown',\r\n                estimatedValue: String(meta?.estimatedValue || '0'),\r\n                image_url: item.image_url,\r\n            }\r\n        })\r\n    }\r\n\r\n    // Fetch market prices\r\n    const { data: prices } = await supabase\r\n        .from('market_prices')\r\n        .select('name, symbol, price, unit')\r\n        .order('name')\r\n\r\n    // Fetch dealer profile\r\n    const { data: profile } = await supabase\r\n        .from('users')\r\n        .select('first_name, last_name, trust_score, business_name')\r\n        .eq('id', user.id)\r\n        .single()\r\n\r\n    const dealerName = profile?.business_name\r\n        || [profile?.first_name, profile?.last_name].filter(Boolean).join(' ')\r\n        || 'Dealer'\r\n\r\n    return {\r\n        items,\r\n        marketPrices: prices || [],\r\n        dealerName,\r\n        trustScore: profile?.trust_score || 30,\r\n    }\r\n}\r\n"],"names":[],"mappings":";;;;;;;MAqPsB,wBAAA,WAAA,GAAA,IAAA,+OAAA,EAAA,8CAAA,oOAAA,EAAA,KAAA,GAAA,0OAAA,EAAA,+CAAA"}},
    {"offset": {"line": 144, "column": 0}, "map": {"version":3,"sources":["file:///C:/Users/anugr/Serious_Projects/UrbanMineAI/src/components/dealer/chat/DealCard.tsx"],"sourcesContent":["'use client';\r\n\r\nimport React, { useState } from 'react';\r\nimport { Gavel, AlertTriangle, Edit, CheckCircle, Loader2 } from 'lucide-react';\r\nimport { acceptOffer } from '@/app/actions/negotiation';\r\n\r\ninterface DealCardProps {\r\n    negotiationId: string;\r\n    pricePerKg: number;\r\n    totalValue: number;\r\n    weight: number;\r\n    unit?: string;\r\n    conditions?: string;\r\n    paymentTerms?: string;\r\n    onCounter?: (counterMessage: string) => void;\r\n    onAccepted?: (transactionId: string) => void;\r\n}\r\n\r\nexport function DealCard({\r\n    negotiationId,\r\n    pricePerKg,\r\n    totalValue,\r\n    weight,\r\n    unit = 'kg',\r\n    conditions = 'Subject to physical verification upon delivery.',\r\n    paymentTerms = 'Instant via Stripe/UPI.',\r\n    onCounter,\r\n    onAccepted,\r\n}: DealCardProps) {\r\n    const [isAccepting, setIsAccepting] = useState(false);\r\n    const [isCountering, setIsCountering] = useState(false);\r\n    const [counterPrice, setCounterPrice] = useState('');\r\n    const [accepted, setAccepted] = useState(false);\r\n    const [error, setError] = useState('');\r\n\r\n    async function handleAccept() {\r\n        if (!negotiationId) return;\r\n        setIsAccepting(true);\r\n        setError('');\r\n        try {\r\n            const result = await acceptOffer(negotiationId);\r\n            setAccepted(true);\r\n            onAccepted?.(result.transactionId);\r\n        } catch (err) {\r\n            setError(err instanceof Error ? err.message : 'Failed to accept offer');\r\n        } finally {\r\n            setIsAccepting(false);\r\n        }\r\n    }\r\n\r\n    function handleCounter() {\r\n        if (isCountering && counterPrice.trim()) {\r\n            const msg = `I'd like to counter-offer at $${counterPrice}/${unit}. That would be $${(parseFloat(counterPrice) * weight).toFixed(2)} total for ${weight}${unit}.`;\r\n            onCounter?.(msg);\r\n            setIsCountering(false);\r\n            setCounterPrice('');\r\n        } else {\r\n            setIsCountering(true);\r\n        }\r\n    }\r\n\r\n    if (accepted) {\r\n        return (\r\n            <div className=\"relative w-full max-w-md my-4 animate-in fade-in slide-in-from-bottom-4 duration-700\">\r\n                <div className=\"relative bg-[#0d1a12] border border-[#19e66b]/30 rounded-xl overflow-hidden shadow-2xl\">\r\n                    <div className=\"bg-[#19e66b]/10 border-b border-[#19e66b]/20 p-4 flex justify-between items-center\">\r\n                        <div className=\"flex items-center gap-2 text-[#19e66b] font-bold\">\r\n                            <CheckCircle size={18} />\r\n                            Deal Accepted\r\n                        </div>\r\n                        <span className=\"text-xs text-[#19e66b]/70 bg-[#19e66b]/10 px-2 py-1 rounded border border-[#19e66b]/20\">\r\n                            Confirmed\r\n                        </span>\r\n                    </div>\r\n                    <div className=\"p-6 text-center\">\r\n                        <p className=\"text-gray-300 text-sm mb-2\">Transaction created successfully!</p>\r\n                        <p className=\"text-2xl font-bold text-[#19e66b]\">${totalValue.toFixed(2)}</p>\r\n                        <p className=\"text-xs text-gray-500 mt-1\">for {weight}{unit} at ${pricePerKg.toFixed(2)}/{unit}</p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    return (\r\n        <div className=\"relative w-full max-w-md my-4 animate-in fade-in slide-in-from-bottom-4 duration-700\">\r\n            <div className=\"absolute -inset-1 bg-gradient-to-r from-[#19e66b] to-emerald-600 rounded-2xl opacity-20 blur transition duration-1000 group-hover:opacity-100 group-hover:duration-200\"></div>\r\n            <div className=\"relative bg-[#0d1a12] border border-[#19e66b]/30 rounded-xl p-0 overflow-hidden shadow-2xl\">\r\n                {/* Header */}\r\n                <div className=\"bg-[#19e66b]/10 border-b border-[#19e66b]/20 p-4 flex justify-between items-center\">\r\n                    <div className=\"flex items-center gap-2 text-[#19e66b] font-bold\">\r\n                        <Gavel size={18} />\r\n                        Proposed Offer\r\n                    </div>\r\n                    <span className=\"text-xs text-[#19e66b]/70 bg-[#19e66b]/10 px-2 py-1 rounded border border-[#19e66b]/20\">\r\n                        Official Bid\r\n                    </span>\r\n                </div>\r\n\r\n                {/* Content */}\r\n                <div className=\"p-6\">\r\n                    <div className=\"flex justify-between items-end mb-6\">\r\n                        <div>\r\n                            <p className=\"text-sm text-gray-400 mb-1\">Price per {unit}</p>\r\n                            <p className=\"text-3xl font-bold text-white\">\r\n                                ${pricePerKg.toFixed(2)}<span className=\"text-lg text-gray-500 font-normal\">/{unit}</span>\r\n                            </p>\r\n                        </div>\r\n                        <div className=\"text-right\">\r\n                            <p className=\"text-sm text-gray-400 mb-1\">Total Estimated Value</p>\r\n                            <p className=\"text-xl font-semibold text-emerald-400\">${totalValue.toFixed(2)}</p>\r\n                            <p className=\"text-xs text-gray-500\">for {weight}{unit} net weight</p>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div className=\"bg-[#112117]/50 rounded-lg p-3 mb-6 border border-white/5\">\r\n                        <div className=\"flex items-start gap-3\">\r\n                            <AlertTriangle className=\"text-yellow-500 mt-0.5 shrink-0\" size={16} />\r\n                            <p className=\"text-xs text-gray-300 leading-relaxed\">\r\n                                Condition: {conditions} <br />\r\n                                Payment Terms: {paymentTerms}\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n\r\n                    {/* Counter input */}\r\n                    {isCountering && (\r\n                        <div className=\"mb-4 flex gap-2 items-center\">\r\n                            <span className=\"text-gray-400 text-sm\">$</span>\r\n                            <input\r\n                                type=\"number\"\r\n                                step=\"0.01\"\r\n                                min=\"0\"\r\n                                value={counterPrice}\r\n                                onChange={(e) => setCounterPrice(e.target.value)}\r\n                                placeholder={pricePerKg.toFixed(2)}\r\n                                className=\"flex-1 bg-[#112117] border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:border-[#19e66b]/50 focus:ring-1 focus:ring-[#19e66b]/50 focus:outline-none\"\r\n                                autoFocus\r\n                            />\r\n                            <span className=\"text-gray-400 text-sm\">/{unit}</span>\r\n                        </div>\r\n                    )}\r\n\r\n                    {error && (\r\n                        <p className=\"text-red-400 text-xs mb-3\">{error}</p>\r\n                    )}\r\n\r\n                    <div className=\"grid grid-cols-2 gap-3\">\r\n                        <button\r\n                            onClick={handleCounter}\r\n                            disabled={isAccepting}\r\n                            className=\"py-2.5 px-4 rounded-lg border border-gray-600 text-gray-300 hover:bg-white/5 hover:text-white font-medium text-sm transition-colors flex items-center justify-center gap-2 disabled:opacity-50\"\r\n                        >\r\n                            <Edit size={16} />\r\n                            {isCountering ? 'Send Counter' : 'Counter'}\r\n                        </button>\r\n                        <button\r\n                            onClick={handleAccept}\r\n                            disabled={isAccepting || isCountering}\r\n                            className=\"py-2.5 px-4 rounded-lg bg-[#19e66b] hover:bg-green-400 text-[#112117] font-bold text-sm transition-colors shadow-lg shadow-[#19e66b]/20 flex items-center justify-center gap-2 disabled:opacity-50\"\r\n                        >\r\n                            {isAccepting ? (\r\n                                <Loader2 size={16} className=\"animate-spin\" />\r\n                            ) : (\r\n                                <CheckCircle size={16} />\r\n                            )}\r\n                            {isAccepting ? 'Processing...' : 'Accept Deal'}\r\n                        </button>\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"bg-[#112117] p-2 text-center border-t border-white/5\">\r\n                    <p className=\"text-[10px] text-gray-500 flex items-center justify-center gap-1\">\r\n                        ✨ Generated by UrbanMine AI Broker based on live market data\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n"],"names":[],"mappings":";;;;;AAEA;AACA;AAAA;AAAA;AAAA;AAAA;AACA;AAJA;;;;;AAkBO,SAAS,SAAS,EACrB,aAAa,EACb,UAAU,EACV,UAAU,EACV,MAAM,EACN,OAAO,IAAI,EACX,aAAa,iDAAiD,EAC9D,eAAe,yBAAyB,EACxC,SAAS,EACT,UAAU,EACE;IACZ,MAAM,CAAC,aAAa,eAAe,GAAG,IAAA,iNAAQ,EAAC;IAC/C,MAAM,CAAC,cAAc,gBAAgB,GAAG,IAAA,iNAAQ,EAAC;IACjD,MAAM,CAAC,cAAc,gBAAgB,GAAG,IAAA,iNAAQ,EAAC;IACjD,MAAM,CAAC,UAAU,YAAY,GAAG,IAAA,iNAAQ,EAAC;IACzC,MAAM,CAAC,OAAO,SAAS,GAAG,IAAA,iNAAQ,EAAC;IAEnC,eAAe;QACX,IAAI,CAAC,eAAe;QACpB,eAAe;QACf,SAAS;QACT,IAAI;YACA,MAAM,SAAS,MAAM,IAAA,4KAAW,EAAC;YACjC,YAAY;YACZ,aAAa,OAAO,aAAa;QACrC,EAAE,OAAO,KAAK;YACV,SAAS,eAAe,QAAQ,IAAI,OAAO,GAAG;QAClD,SAAU;YACN,eAAe;QACnB;IACJ;IAEA,SAAS;QACL,IAAI,gBAAgB,aAAa,IAAI,IAAI;YACrC,MAAM,MAAM,CAAC,8BAA8B,EAAE,aAAa,CAAC,EAAE,KAAK,iBAAiB,EAAE,CAAC,WAAW,gBAAgB,MAAM,EAAE,OAAO,CAAC,GAAG,WAAW,EAAE,SAAS,KAAK,CAAC,CAAC;YACjK,YAAY;YACZ,gBAAgB;YAChB,gBAAgB;QACpB,OAAO;YACH,gBAAgB;QACpB;IACJ;IAEA,IAAI,UAAU;QACV,qBACI,8OAAC;YAAI,WAAU;sBACX,cAAA,8OAAC;gBAAI,WAAU;;kCACX,8OAAC;wBAAI,WAAU;;0CACX,8OAAC;gCAAI,WAAU;;kDACX,8OAAC,0OAAW;wCAAC,MAAM;;;;;;oCAAM;;;;;;;0CAG7B,8OAAC;gCAAK,WAAU;0CAAyF;;;;;;;;;;;;kCAI7G,8OAAC;wBAAI,WAAU;;0CACX,8OAAC;gCAAE,WAAU;0CAA6B;;;;;;0CAC1C,8OAAC;gCAAE,WAAU;;oCAAoC;oCAAE,WAAW,OAAO,CAAC;;;;;;;0CACtE,8OAAC;gCAAE,WAAU;;oCAA6B;oCAAK;oCAAQ;oCAAK;oCAAM,WAAW,OAAO,CAAC;oCAAG;oCAAE;;;;;;;;;;;;;;;;;;;;;;;;IAK9G;IAEA,qBACI,8OAAC;QAAI,WAAU;;0BACX,8OAAC;gBAAI,WAAU;;;;;;0BACf,8OAAC;gBAAI,WAAU;;kCAEX,8OAAC;wBAAI,WAAU;;0CACX,8OAAC;gCAAI,WAAU;;kDACX,8OAAC,6MAAK;wCAAC,MAAM;;;;;;oCAAM;;;;;;;0CAGvB,8OAAC;gCAAK,WAAU;0CAAyF;;;;;;;;;;;;kCAM7G,8OAAC;wBAAI,WAAU;;0CACX,8OAAC;gCAAI,WAAU;;kDACX,8OAAC;;0DACG,8OAAC;gDAAE,WAAU;;oDAA6B;oDAAW;;;;;;;0DACrD,8OAAC;gDAAE,WAAU;;oDAAgC;oDACvC,WAAW,OAAO,CAAC;kEAAG,8OAAC;wDAAK,WAAU;;4DAAoC;4DAAE;;;;;;;;;;;;;;;;;;;kDAGtF,8OAAC;wCAAI,WAAU;;0DACX,8OAAC;gDAAE,WAAU;0DAA6B;;;;;;0DAC1C,8OAAC;gDAAE,WAAU;;oDAAyC;oDAAE,WAAW,OAAO,CAAC;;;;;;;0DAC3E,8OAAC;gDAAE,WAAU;;oDAAwB;oDAAK;oDAAQ;oDAAK;;;;;;;;;;;;;;;;;;;0CAI/D,8OAAC;gCAAI,WAAU;0CACX,cAAA,8OAAC;oCAAI,WAAU;;sDACX,8OAAC,yOAAa;4CAAC,WAAU;4CAAkC,MAAM;;;;;;sDACjE,8OAAC;4CAAE,WAAU;;gDAAwC;gDACrC;gDAAW;8DAAC,8OAAC;;;;;gDAAK;gDACd;;;;;;;;;;;;;;;;;;4BAM3B,8BACG,8OAAC;gCAAI,WAAU;;kDACX,8OAAC;wCAAK,WAAU;kDAAwB;;;;;;kDACxC,8OAAC;wCACG,MAAK;wCACL,MAAK;wCACL,KAAI;wCACJ,OAAO;wCACP,UAAU,CAAC,IAAM,gBAAgB,EAAE,MAAM,CAAC,KAAK;wCAC/C,aAAa,WAAW,OAAO,CAAC;wCAChC,WAAU;wCACV,SAAS;;;;;;kDAEb,8OAAC;wCAAK,WAAU;;4CAAwB;4CAAE;;;;;;;;;;;;;4BAIjD,uBACG,8OAAC;gCAAE,WAAU;0CAA6B;;;;;;0CAG9C,8OAAC;gCAAI,WAAU;;kDACX,8