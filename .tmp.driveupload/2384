ventoryItem[]>([]);\r\n    const [selectedItems, setSelectedItems] = useState<string[]>([]);\r\n    const [newTitle, setNewTitle] = useState('');\r\n    const [isCreating, setIsCreating] = useState(false);\r\n    const [isLoadingNeg, setIsLoadingNeg] = useState(true);\r\n    const [sidebarSearch, setSidebarSearch] = useState('');\r\n\r\n    const scrollRef = useRef<HTMLDivElement>(null);\r\n\r\n    // ─── Transport (AI SDK v6) ───────────────────────────────\r\n    const transport = useMemo(() => new DefaultChatTransport({\r\n        api: '/api/broker',\r\n        body: { negotiationId: activeNegotiationId },\r\n    }), [activeNegotiationId]);\r\n\r\n    // ─── Chat hook (AI SDK v6) ───────────────────────────────\r\n    const { messages, status, setMessages, sendMessage } = useChat({\r\n        transport,\r\n    });\r\n\r\n    const isBusy = status === 'submitted' || status === 'streaming';\r\n\r\n    // ─── Load negotiations list ──────────────────────────────\r\n    const loadNegotiations = useCallback(async () => {\r\n        setIsLoadingNeg(true);\r\n        try {\r\n            const negs = await getNegotiations();\r\n            setNegotiations(negs);\r\n        } catch (e) {\r\n            console.error('Failed to load negotiations:', e);\r\n        } finally {\r\n            setIsLoadingNeg(false);\r\n        }\r\n    }, []);\r\n\r\n    // ─── Load user profile ───────────────────────────────────\r\n    useEffect(() => {\r\n        loadNegotiations();\r\n        getUserProfile().then((p) => {\r\n            setProfile({\r\n                name: p.name,\r\n                trustScore: p.trust_score,\r\n                isVerified: p.isVerified,\r\n            });\r\n        }).catch(console.error);\r\n    }, [loadNegotiations]);\r\n\r\n    // ─── Load a specific negotiation ─────────────────────────\r\n    const selectNegotiation = useCallback(async (id: string) => {\r\n        setActiveNegotiationId(id);\r\n        try {\r\n            const { negotiation, messages: dbMessages } = await getNegotiation(id);\r\n            setActiveNegotiation(negotiation);\r\n            // Convert DB messages to useChat format (exclude system messages)\r\n            const chatMessages = dbMessages\r\n                .filter(m => m.role !== 'system')\r\n                .map((m) => ({\r\n                    id: m.id,\r\n                    role: m.role as 'user' | 'assistant',\r\n                    parts: [{ type: 'text' as const, text: m.content }],\r\n                }));\r\n            setMessages(chatMessages);\r\n        } catch (e) {\r\n            console.error('Failed to load negotiation:', e);\r\n        }\r\n    }, [setMessages]);\r\n\r\n    // ─── Send message ────────────────────────────────────────\r\n    const handleSend = useCallback(() => {\r\n        const text = draft.trim();\r\n        if (!text || isBusy || !activeNegotiationId) return;\r\n        setDraft('');\r\n        sendMessage({ text });\r\n    }, [draft, isBusy, activeNegotiationId, sendMessage]);\r\n\r\n    // ─── Create new negotiation ──────────────────────────────\r\n    const handleCreateNegotiation = useCallback(async () => {\r\n        if (isCreating) return;\r\n        setIsCreating(true);\r\n        try {\r\n            const title = newTitle.trim() || `Negotiation ${negotiations.length + 1}`;\r\n            const result = await createNegotiation(title, selectedItems);\r\n            if (result) {\r\n                setShowNewDialog(false);\r\n                setNewTitle('');\r\n                setSelectedItems([]);\r\n                await loadNegotiations();\r\n                await selectNegotiation(result.id);\r\n            }\r\n        } catch (e) {\r\n            console.error('Failed to create negotiation:', e);\r\n        } finally {\r\n            setIsCreating(false);\r\n        }\r\n    }, [isCreating, newTitle, negotiations.length, selectedItems, loadNegotiations, selectNegotiation]);\r\n\r\n    // ─── Open new dialog ───────────────────