 }\r\n        return m.content || '';\r\n    }\r\n\r\n    // ─── Render ──────────────────────────────────────────────\r\n    return (\r\n        <div className=\"flex h-[calc(100vh-80px)] -m-4 md:-m-8 bg-[#112117] text-gray-100 font-sans relative overflow-hidden\">\r\n\r\n            {/* ═══════ SIDEBAR ═══════ */}\r\n            <aside className=\"w-72 lg:w-80 h-full bg-[#0d1a12] border-r border-white/5 flex flex-col z-20 shadow-xl shrink-0\">\r\n                {/* Logo */}\r\n                <div className=\"p-5 flex items-center gap-3 border-b border-white/5\">\r\n                    <div className=\"w-8 h-8 rounded-lg bg-[#19e66b] flex items-center justify-center text-[#112117] font-bold\">\r\n                        <span className=\"text-lg\">♻</span>\r\n                    </div>\r\n                    <h1 className=\"text-lg font-bold tracking-tight text-white\">\r\n                        UrbanMine<span className=\"text-[#19e66b]\">AI</span>\r\n                    </h1>\r\n                </div>\r\n\r\n                {/* Search */}\r\n                <div className=\"px-4 py-3\">\r\n                    <div className=\"relative\">\r\n                        <Search className=\"absolute left-3 top-2.5 text-gray-500\" size={14} />\r\n                        <input\r\n                            className=\"w-full bg-white/5 border border-white/5 rounded-lg py-2 pl-9 pr-4 text-sm focus:ring-1 focus:ring-[#19e66b] text-gray-300 placeholder-gray-500 focus:outline-none\"\r\n                            placeholder=\"Search negotiations...\"\r\n                            value={sidebarSearch}\r\n                            onChange={(e) => setSidebarSearch(e.target.value)}\r\n                        />\r\n                    </div>\r\n                </div>\r\n\r\n                {/* New Negotiation Button */}\r\n                <div className=\"px-4 pb-3\">\r\n                    <button\r\n                        onClick={openNewDialog}\r\n                        className=\"w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-[#19e66b]/10 border border-[#19e66b]/20 text-[#19e66b] text-sm font-medium hover:bg-[#19e66b]/20 transition-colors\"\r\n                    >\r\n                        <Plus size={16} />\r\n                        New Negotiation\r\n                    </button>\r\n                </div>\r\n\r\n                {/* Negotiations List */}\r\n                <ScrollArea className=\"flex-1 px-2\">\r\n                    {isLoadingNeg ? (\r\n                        <div className=\"flex items-center justify-center py-8\">\r\n                            <Loader2 className=\"animate-spin text-gray-500\" size={20} />\r\n                        </div>\r\n                    ) : negotiations.length === 0 ? (\r\n                        <div className=\"text-center py-8 px-4\">\r\n                            <p className=\"text-gray-500 text-sm\">No negotiations yet.</p>\r\n                            <p className=\"text-gray-600 text-xs mt-1\">Start one to begin trading!</p>\r\n                        </div>\r\n                    ) : (\r\n                        <div className=\"space-y-4 pb-4\">\r\n                            {filteredActive.length > 0 && (\r\n                                <div>\r\n                                    <h3 className=\"px-3 text-[10px] font-semibold text-[#19e66b] uppercase tracking-wider mb-2\">\r\n                                        Active Negotiations\r\n                                    </h3>\r\n                                    <ul className=\"space-y-1\">\r\n                                        {filteredActive.map((neg) => (\r\n                                            <li key={neg.id}>\r\n                                                <button\r\n                                                    onClick={() => selectNegotiation(neg.id)}\r\n                                                    className={`block w-full text-left p-3 rounded-lg transition-all group border ${activeNegotiationId === neg.id\r\n                                                        ? 'bg-[#19e66b]/10 border-[#19e66b]/20'\r\n                                                        : 'border-transparent hover:bg-white/5'\r\n                                                        }`}\r\n                                                >\r\n                                                    <div className=\"flex justify-between items-start mb-1\">\r\n                                                        <div className=\"flex items-center gap-2\">\r\n                                                            <div className=\"relative\">\r\n                                                                <div className=\"w-8 h-8 rounded-full bg-[#19e66b]/20 text-[#19e66b] flex items-center justify-center text-xs font-bold border border-[#19e66b]/30\">\r\n                                                                    {neg.title.slice(0, 2).toUpperCase()}\r\n                                                                </div>\r\n                                                                <span className=\"absolute bottom-0 right-0 w-2.5 h-2.5 bg-[#19e66b] border-2 border-[#0d1a12] rounded-full\"></span>\r\n                                                            </div>\r\n                                                            <span className=\"font-medium text-sm text-gray-200 group-hover:text-[#19e66b] transition-colors line-clamp-1\">\r\n                                                                {neg.title}\r\n                                                            </span>\r\n                                                        </div>\r\n                                                        <span className=\"text-[10px] text-[#19e66b] font-medium shrink-0 ml-2\">\r\n                                                            {formatTime(neg.last_message_at)}\r\n                                                        </span>\r\n                                                    </div>\r\n                                                    {neg.last_message && (\r\n                                                        <p className=\"text-xs text-gray-500 line-clamp-1 pl-10\">\r\n                                                            {neg.last_message}\r\n                                                        </p>\r\n                                                    )}\r\n                                                </button>\r\n                                            </li>\r\n                                        ))}\r\n                                    </ul>\r\n                                </div>\r\n                            )}\r\n\r\n                            {filteredClosed.length > 0 && (\r\n                                <div>\r\n                                    <h3 className=\"px-3 text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-2\">\r\n                                        Closed Deals\r\n                                    </h3>\r\n                                    <ul className=\"space-y-1 opacity-70\">\r\n                                        {filteredClosed.map((neg) => (\r\n                                            <li key={neg.id}>\r\n                                                <button\r\n                                                    onClick={() => selectNegotiation(neg.id)}\r\n                                                    className={`block w-full text-left p-3 rounded-lg transition-all border ${activeNegotiationId === neg.id\r\n                                                        ? 'bg-white/5 border-white/10'\r\n                                                        : 'border-transparent hover:bg-white/5'\r\n                                                        }`}\r\n                                                >\r\n                                                    <div className=\"flex justify-between items-start mb-1\">\r\n                                                        <div className=\"flex items-center gap-2\">\r\n                                                            <div className=\"w-8 h-8 rounded-full bg-gray-700/50 text-gray-400 flex items-center justify-center text-xs font-bold border border-gray-600/30\">\r\n                                                                {neg.title.slice(0, 2).toUpperCase()}\r\n                                                            </div>\r\n                                                            <span className=\"font-medium text-sm text-gray-400\">\r\n                                                                {neg.title}\r\n                                                            </span>\r\n                                                        </div>\r\n                                                        <span className=\"text-[10px] text-gray-600 shrink-0 ml-2\">\r\n                                                            {formatDate(neg.created_at)}\r\n                                                        </span>\r\n                                                    </div>\r\n                                                    {neg.last_message && (\r\n                                                        <p className=\"text-xs text-gray-600 line-clamp-1 pl-10\">\r\n                                                            {neg.last_message}\r\n                                                        </p>\r\n                                                    )}\r\n                                                </button>\r\n                                            </li>\r\n                                        ))}\r\n                                    </ul>\r\n                                </div>\r\n                            )}\r\n                        </div>\r\n                    )}\r\n                </ScrollArea>\r\n\r\n                {/* Profile */}\r\n                {profile && (\r\n                    <div className=\"p-4 border-t border-white/5 flex items-center gap-3\">\r\n                        <div className=\"w-8 h-8 rounded-full bg-gradient-to-tr from-[#19e66b] to-emerald-600 flex items-center justify-center text-[#112117] font-bold text-xs\">\r\n                            {profile.name.slice(0, 2).toUpperCase()}\r\n                        </div>\r\n                        <div className=\"flex-1 min-w-0\">\r\n                            <p className=\"text-sm font-medium text-white truncate\">{profile.name}</p>\r\n                            <p className=\"text-[10px] text-[#19e66b]\">Trust: {profile.trustScore}/100</p>\r\n                        </div>\r\n                    </div>\r\n                )}\r\n            </aside>\r\n\r\n            {/* ═══════ MAIN CHAT ═══════ */}\r\n            <main className=\"flex-1 flex flex-col h-full relative min-w-0\">\r\n                {activeNegotiationId && activeNegotiation ? (\r\n                    <>\r\n                        {/* Header */}\r\n                        <header className=\"h-14 border-b border-white/5 bg-[#112117]/50 backdrop-blur-md flex items-center justify-between px-6 z-10 sticky top-0 shrink-0\">\r\n                            <div className=\"flex items-center gap-4\">\r\n                                <div className=\"relative\">\r\n                                    <div className=\"w-9 h-9 rounded-full bg-[#19e66b]/20 border-2 border-[#19e66b]/20 flex items-center justify-center text-[#19e66b] text-xs font-bold\">\r\n                                        {activeNegotiation.title.slice(0, 2).toUpperCase()}\r\n                                    </div>\r\n                                    {activeNegotiation.status === 'active' && (\r\n                                        <div className=\"absolute -bottom-1 -right-1 bg-[#112117] rounded-full p-0.5\">\r\n                                            <div className=\"w-2.5 h-2.5 bg-[#19e66b] rounded-full animate-pulse shadow-[0_0_10px_#19e66b]\"></div>\r\n                                        </div>\r\n                                    )}\r\n                                </div>\r\n                                <div>\r\n                                    <h2 className=\"text-sm font-bold text-white flex items-center gap-2\">\r\n                                        {activeNegotiation.title}\r\n                                        <span className=\"px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-[9px] text-gray-400 uppercase font-semibold tracking-wide\">\r\n                                            #{activeNegotiation.id.slice(0, 8)}\r\n                                        </span>\r\n                                    </h2>\r\n                                    <div className=\"flex items-center gap-3 text-[10px]\">\r\n                                        <span className={`font-medium flex items-center gap-1 ${activeNegotiation.status === 'active' ? 'text-[#19e66b]' : 'text-gray-400'\r\n                                            }`}>\r\n                                            <span className={`w-1.5 h-1.5 rounded-full ${activeNegotiation.status === 'active' ? 'bg-[#19e66b]' : 'bg-gray-500'\r\n                                                }`}></span>\r\n                                            {activeNegotiation.status === 'active' ? 'Active Negotiation' :\r\n                                                activeNegotiation.status === 'accepted' ? 'Deal Accepted' :\r\n                                                    'Closed'}\r\n                                        </span>\r\n                                        {profile && (\r\n                                            <>\r\n                                                <span className=\"text-gray-500\">|</span>\r\n                                                <span className=\"text-gray-400 flex items-center gap-1\">\r\n                                                    {profile.isVerified && <span className=\"text-yellow-500\">✓</span>}\r\n                                                    Trust Score: {profile.trustScore}/100\r\n                                                </span>\r\n                                            </>\r\n                                        )}\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n\r\n                            <div className=\"flex items-center gap-2\">\r\n                                <Button variant=\"secondary\" className=\"bg-white/5 border-white/5 text-gray-300 hover:bg-white/10 hover:text-white text-xs h-8 hidden md:flex\">\r\n                                    <Package size={14} className=\"mr-1.5\" /> Inventory\r\n                                </Button>\r\n                                <Button variant=\"secondary\" className=\"bg-white/5 border-white/5 text-gray-300 hover:bg-white/10 hover:text-white text-xs h-8 hidden md:flex\">\r\n                                    <History size={14} className=\"mr-1.5\" /> Prices\r\n                                </Button>\r\n                                <Button variant=\"ghost\" size=\"icon\" className=\"text-gray-400 hover:text-white h-8 w-8\">\r\n                                    <MoreVertical size={16} />\r\n                                </Button>\r\n                            </div>\r\n                        </header>\r\n\r\n                        {/* Messages */}\r\n                        <ScrollArea className=\"flex-1 p-0 bg-[#0d1a12]\" ref={scrollRef}>\r\n                            <div className=\"p-6 space-y-6 min-h-full bg-[radial-gradient(#1a2e22_1px,transparent_1px)] [background-size:16px_16px]\">\r\n                                <div className=\"flex justify-center\">\r\n                                    <span className=\"px-3 py-1 rounded-full bg-white/5 text-[10px] font-medium text-gray-500 border border-white/5 uppercase tracking-wide\">\r\n                                        {formatDate(activeNegotiation.created_at)}\r\n                                    </span>\r\n                                </div>\r\n\r\n                                {messages.length === 0 && !isBusy && (\r\n                                    <div className=\"text-center py-12\">\r\n                                        <Bot size={48} className=\"mx-auto text-gray-600 mb-4\" />\r\n                                        <p className=\"text-gray-400 text-sm\">Start the conversation.</p>\r\n                                        <p className=\"text-gray-600 text-xs mt-1\">\r\n                                            Describe your materials and the AI Broker will help you negotiate.\r\n                                        </p>\r\n                                    </div>\r\n                                )}\r\n\r\n                                {messages.map((m) => {\r\n                                    // Check for tool invocations (deal proposals)\r\n                                    const toolInvocations = m.parts?.filter(\r\n                                        (p) => p.type === 'tool-invocation' && (p as any).toolInvocation?.toolName === 'proposeDeal'\r\n                                    );\r\n\r\n                                    const text = getMessageText(m as any);\r\n\r\n                                    return (\r\n                                        <div key={m.id}>\r\n                                            {text && (\r\n                                                <div\r\n                                                    className={`flex gap-3 max-w-3xl ${m.role === 'user' ? 'ml-0' : 'ml-auto flex-row-reverse'\r\n                                                        }`}\r\n                                                >\r\n                                                    <div className={`w-7 h-7 rounded-full flex items-center justify-center shrink-0 mt-1 ${m.role === 'user'\r\n                                                        ? 'bg-white/10 border border-white/10 text-gray-400'\r\n                                                        : 'bg-[#19e66b]/20 border border-[#19e66b]/40 text-[#19e66b] shadow-[0_0_10px_rgba(25,230,107,0.2)]'\r\n                                                        }`}>\r\n                                                        {m.role === 'user' ? (\r\n                                                            <span className=\"text-xs font-bold\">\r\n                                                                {profile?.name?.slice(0, 1) || 'U'}\r\n                                                            </span>\r\n                                                        ) : (\r\n                                                            <Bot size={14} />\r\n                                                        )}\r\n                                                    </div>\r\n\r\n                                                    <div className={`flex flex-col gap-1 ${m.role === 'assistant' ? 'items-end' : 'items-start'}`}>\r\n                                                        <div className=\"flex items-baseline gap-2\">\r\n                                                            <span className={`text-xs font-medium ${m.role === 'assistant' ? 'text-[#19e66b]' : 'text-gray-300'}`}>\r\n                                                                {m.role === 'assistant' ? 'UrbanMine AI Broker' : profile?.name || 'You'}\r\n                                                            </span>\r\n                                                        </div>\r\n\r\n                                                        <div className={`p-3.5 rounded-xl text-sm leading-relaxed shadow-sm text-gray-200 max-w-2xl ${m.role === 'user'\r\n                                                            ? 'rounded-tl-none bg-[#182e21] border border-white/5'\r\n                                                            : 'rounded-tr-none bg-[#19e66b]/5 border border-[#19e66b]/20'\r\n                                                            }`}>\r\n                                                            {m.role === 'assistant' && (\r\n                                                                <div className=\"flex items-center gap-1.5 mb-2 text-[10px] text-[#19e66b] font-semibold uppercase tracking-wider\">\r\n                                                                    <Bot size={12} /> AI Broker\r\n                                                                </div>\r\n                                                            )}\r\n                                                            <div className=\"whitespace-pre-wrap\">{text}</div>\r\n                                                        </div>\r\n                                                    </div>\r\n                                                </div>\r\n                                            )}\r\n\r\n                                            {toolInvocations?.map((part, i) => {\r\n                                                const result = (part as any).toolInvocation?.result;\r\n                                                if (!result) return null;\r\n                                                return (\r\n                                                    <div key={`deal-${m.id}-${i}`} className=\"flex flex-row-reverse gap-4 w-full ml-auto justify-center my-4\">\r\n                                                        <DealCard\r\n                                                            negotiationId={activeNegotiationId!}\r\n                                                            pricePerKg={result.pricePerUnit}\r\n                                                            totalValue={result.totalValue}\r\n                                                            weight={result.weight}\r\n                                                            unit={result.unit}\r\n                                                            conditions={result.conditions}\r\n                                                            paymentTerms={result.paymentTerms}\r\n                                                            onCounter={handleCounterOffer}\r\n                                                            onAccepted={() => loadNegotiations()}\r\n                                                        />\r\n                                                    </div>\r\n                                                );\r\n                                            })}\r\n                                        </div>\r\n                                    );\r\n                                })}\r\n\r\n                                {/* Fallback: show existing offer from DB */}\r\n                                {activeNegotiation.proposed_price_per_unit &&\r\n                                    activeNegotiation.status === 'active' &&\r\n                                    !messages.some((m) => m.parts?.some((p) => p.type === 'tool-invocation' && (p as any).toolInvocation?.toolName === 'proposeDeal')) && (\r\n                                        <div className=\"flex flex-row-reverse gap-4 w-full ml-auto justify-center my-4\">\r\n                                            <DealCard\r\n                                                negotiationId={activeNegotiationId!}\r\n                                                pricePerKg={Number(activeNegotiation.proposed_price_per_unit)}\r\n                                                totalValue={Number(activeNegotiation.proposed_total)}\r\n                                                weight={Number(activeNegotiation.proposed_weight)}\r\n                                                unit={activeNegotiation.proposed_unit}\r\n                                                onCounter={handleCounterOffer}\r\n                                                onAccepted={() => loadNegotiations()}\r\n                                            />\r\n                                        </div>\r\n                                    )}\r\n\r\n                                {isBusy && (\r\n                                    <div className=\"flex justify-center p-4\">\r\n                                        <RefreshCw className=\"animate-spin text-[#19e66b]\" size={18} />\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n                        </ScrollArea>\r\n\r\n                        {/* Input Area */}\r\n                        {activeNegotiation.status === 'active' && (\r\n                            <div className=\"border-t border-white/5 bg-[#0d1a12] p-4 z-20 shrink-0\">\r\n                                <div className=\"max-w-4xl mx-auto\">\r\n                                    <div className=\"flex items-center justify-between mb-2 px-1\">\r\n                                        <div className=\"flex gap-2\">\r\n                                            <button className=\"text-[10px] bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white px-3 py-1 rounded-full border border-white/5 transition-colors\">\r\n                                                Request new photos\r\n                                            </button>\r\n                                            <button className=\"text-[10px] bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white px-3 py-1 rounded-full border border-white/5 transition-colors\">\r\n                                                Schedule pickup\r\n                                            </button>\r\n                                        </div>\r\n                                        <div className=\"flex items-center gap-2\">\r\n                                            <span className=\"text-[10px] text-[#19e66b] font-medium\">AI Autopilot</span>\r\n                                            <button className=\"w-8 h-4 bg-[#19e66b]/20 rounded-full relative cursor-pointer border border-[#19e66b]/30\">\r\n                                                <div className=\"absolute right-0.5 top-0.5 w-3 h-3 bg-[#19e66b] rounded-full shadow-sm\"></div>\r\n                                            </button>\r\n                                        </div>\r\n                                    </div>\r\n\r\n                                    <div className=\"relative flex items-end gap-2 bg-[#112117] border border-white/10 rounded-xl p-2 focus-within:border-[#19e66b]/50 focus-within:ring-1 focus-within:ring-[#19e66b]/50 transition-all shadow-lg\">\r\n                                        <button className=\"p-2 text-gray-400 hover:text-[#19e66b] transition-colors\">\r\n                                            <PlusCircle size={18} />\r\n                                        </button>\r\n\r\n                                        <div className=\"flex-1 flex gap-2\">\r\n                                            <textarea\r\n                                                value={draft}\r\n                                                onChange={(e) => setDraft(e.target.value)}\r\n                                                onKeyDown={(e) => {\r\n                                                    if (e.key === 'Enter' && !e.shiftKey) {\r\n                                                        e.preventDefault();\r\n                                                        handleSend();\r\n                                                    }\r\n                                                }}\r\n                                                className=\"w-full bg-transparent border-none text-gray-200 placeholder-gray-600 focus:ring-0 resize-none py-2 max-h-32 text-sm leading-relaxed focus:outline-none\"\r\n                                                placeholder=\"Type your message or let AI draft a response...\"\r\n                                                rows={1}\r\n                                            />\r\n                                            <div className=\"flex items-center gap-1 pb-0.5\">\r\n                                                <button type=\"button\" className=\"p-2 text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-white/5\">\r\n                                                    <Mic size={18} />\r\n                                                </button>\r\n                                                <Button\r\n                                                    onClick={handleSend}\r\n                                                    className=\"bg-[#19e66b] hover:bg-green-400 text-[#112117] rounded-lg transition-colors shadow-lg shadow-[#19e66b]/20\"\r\n                                                    size=\"icon\"\r\n                                                    disabled={isBusy || !draft.trim()}\r\n                                                >\r\n                                                    <Send size={16} />\r\n                                                </Button>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div>\r\n\r\n                                    <p className=\"text-center text-[9px] text-gray-600 mt-2\">\r\n                                        AI can make mistakes. Please verify financial details before accepting.\r\n                                    </p>\r\n                                </div>\r\n                            </div>\r\n                        )}\r\n                    </>\r\n                ) : (\r\n                    /* ─── Empty State ─── */\r\n                    <div className=\"flex-1 flex items-center justify-center bg-[#0d1a12]\">\r\n                        <div className=\"text-center max-w-sm\">\r\n                            <div className=\"w-16 h-16 rounded-2xl bg-[#19e66b]/10 border border-[#19e66b]/20 flex items-center justify-center mx-auto mb-4\">\r\n                                <Bot size={32} className=\"text-[#19e66b]\" />\r\n                            </div>\r\n                            <h2 className=\"text-xl font-bold text-white mb-2\">AI Broker</h2>\r\n                            <p className=\"text-gray-400 text-sm mb-6\">\r\n                                Start a negotiation to get the best price for your e-waste materials.\r\n                                Our AI broker uses live market data to help you maximize value.\r\n                            </p>\r\n                            <button\r\n                                onClick={openNewDialog}\r\n                                className=\"px-6 py-3 rounded-xl bg-[#19e66b] hover:bg-green-400 text-[#112117] font-bold text-sm transition-colors shadow-lg shadow-[#19e66b]/20\"\r\n                            >\r\n                                Start New Negotiation\r\n                            </button>\r\n                        </div>\r\n                    </div>\r\n                )}\r\n            </main>\r\n\r\n            {/* ═══════ NEW NEGOTIATION DIALOG ═══════ */}\r\n            {showNewDialog && (\r\n                <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm\">\r\n                    <div className=\"bg-[#112117] border border-white/10 rounded-2xl w-full max-w-lg mx-4 shadow-2xl\">\r\n                        <div className=\"flex items-center justify-between p-5 border-b border-white/5\">\r\n                            <h3 className=\"text-lg font-bold text-white\">New Negotiation</h3>\r\n                            <button onClick={() => setShowNewDialog(false)} className=\"text-gray-400 hover:text-white\">\r\n                                <X size={20} />\r\n                            </button>\r\n                        </div>\r\n\r\n                        <div className=\"p-5 space-y-4\">\r\n                            <div>\r\n                                <label className=\"block text-xs text-gray-400 mb-1.5 font-medium\">Title</label>\r\n                                <input\r\n                                    value={newTitle}\r\n                                    onChange={(e) => setNewTitle(e.target.value)}\r\n                                    className=\"w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2.5 text-sm text-white focus:border-[#19e66b]/50 focus:ring-1 focus:ring-[#19e66b]/50 focus:outline-none placeholder-gray-500\"\r\n                                    placeholder=\"e.g., Mixed PCB Boards - 200kg\"\r\n                                />\r\n                            </div>\r\n\r\n                            <div>\r\n                                <label className=\"block text-xs text-gray-400 mb-1.5 font-medium\">\r\n                                    Select Items from Inventory (optional)\r\n                                </label>\r\n                                {inventory.length === 0 ? (\r\n                                    <p className=\"text-gray-500 text-sm py-2\">\r\n                                        No inventory items found. You can still start a negotiation and describe your materials.\r\n                                    </p>\r\n                                ) : (\r\n                                    <div className=\"space-y-2 max-h-48 overflow-y-auto\">\r\n                                        {inventory.filter(i => i.status !== 'sold').map((item) => (\r\n                                            <label\r\n                                                key={item.id}\r\n                                                className={`flex items-center gap-3 p-3 rounded-lg border cursor-pointer transition-colors ${selectedItems.includes(item.id)\r\n                                                    ? 'bg-[#19e66b]/10 border-[#19e66b]/30'\r\n                                                    : 'bg-white/5 border-white/5 hover:border-white/10'\r\n                                                    }`}\r\n                                            >\r\n                                                <input\r\n                                                    type=\"checkbox\"\r\n                                                    checked={selectedItems.includes(item.id)}\r\n                                                    onChange={(e) => {\r\n                                                        if (e.target.checked) {\r\n                                                            setSelectedItems([...selectedItems, item.id]);\r\n                                                        } else {\r\n                                                            setSelectedItems(selectedItems.filter(id => id !== item.id));\r\n                                                        }\r\n                                                    }}\r\n                                                    className=\"rounded border-gray-600 bg-transparent text-[#19e66b] focus:ring-[#19e66b]/50\"\r\n                                                />\r\n                                                <div className=\"flex-1 min-w-0\">\r\n                                                    <p className=\"text-sm text-white truncate\">{item.title}</p>\r\n                                                    <p className=\"text-[10px] text-gray-400\">{item.grade} · {item.weight}</p>\r\n                                                </div>\r\n                                                <span className=\"text-xs text-[#19e66b] font-medium shrink-0\">{item.value}</span>\r\n                                            </label>\r\n                           